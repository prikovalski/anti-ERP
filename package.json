{
  "name": "anti-erp",
  "private": true,
  "version": "0.1.0",
  "description": "The first MCP-native AI ERP experiment.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "mcp:dev": "pnpm --filter @anti-erp/mcp-server dev",
    "mcp:customers:dev": "pnpm --filter @anti-erp/mcp-customers dev",
    "mcp:products:dev": "pnpm --filter @anti-erp/mcp-products dev",
    "mcp:suppliers:dev": "pnpm --filter @anti-erp/mcp-suppliers dev",
    "mcp:sales-orders:dev": "pnpm --filter @anti-erp/mcp-sales-orders dev",
    "mcp:invoices:dev": "pnpm --filter @anti-erp/mcp-invoices dev",
    "mcp:analytics:dev": "pnpm --filter @anti-erp/mcp-analytics dev",
    "command-center:dev": "pnpm --filter @anti-erp/command-center dev",
    "langgraph:dev": "pnpm --filter @anti-erp/command-center langgraph:dev"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "erp",
    "nextjs",
    "openai"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@prisma/client": "6",
    "prisma": "^6.19.3",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
