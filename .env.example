# Server-side only. Never prefix secrets with NEXT_PUBLIC_.
OPENROUTER_API_KEY=

# Optional. Defaults to openrouter/free.
OPENROUTER_MODEL=openrouter/free

# Public app URL used only as OpenRouter request metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional MCP/agent observability. Server-side only.
# LANGCHAIN_API_KEY is accepted as an alias for LANGSMITH_API_KEY.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=anti-erp
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Required only when your LangSmith key is workspace-scoped.
LANGSMITH_WORKSPACE_ID=

# Capability execution mode.
# prisma = recommended for local validation and public deploys with Neon/Postgres.
# demo = local in-memory gateway, useful when no database is available.
# mcp = spawn and call domain MCP servers over stdio for local architecture experiments.
CAPABILITY_GATEWAY=prisma
MCP_STDIO_ENABLED=false
MCP_SERVER_COMMAND=pnpm
MCP_SERVER_ARGS=--filter @anti-erp/mcp-server dev

# Required for CAPABILITY_GATEWAY=prisma.
DATABASE_URL=

# API route timeout for agent commands.
AGENT_COMMAND_TIMEOUT_MS=12000
